#import "/styles/ebook-template.typ": *
// ---- PAGE 9: Full Printable Worksheet ----
// Stable internal destination for the page-13 secondary CTA ("Continue With
// My Free 7-Minute Reset"). Placed at the top of the worksheet page so the
// jump lands on page 9.
#metadata("worksheet")<worksheet>

#mcr-ws-open(
  kicker: "Seven Quiet Minutes",
  num: "01",
  title: "Your 7-Minute Morning Reset",
  purpose: "The whole routine on one page. Use a fresh copy each morning, or keep it beside you as you move through the seven minutes.",
)

#mcr-field("1.  What am I carrying into this morning?", lines: 1)
#mcr-field("2.  What thought is taking up the most space?", lines: 1)
#mcr-field("3.  What feeling is underneath it?", lines: 1)
#mcr-field("4.  What do I know for certain?", lines: 1)
#mcr-field("5.  What might I be assuming?", lines: 1)
#mcr-field("6.  What is one useful action I can take?", lines: 1)
#mcr-field("7.  What word will I carry forward?", lines: 1)

#mcr-ws-footer()
#pagebreak(weak: true)
